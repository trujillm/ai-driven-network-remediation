# AI Driven Network Remediation — Configuration Template
# Copy to .env and update with your cluster details

# ─────────────────────────────────────────────────────────────────
# DEPLOYMENT MODE
# ─────────────────────────────────────────────────────────────────
# single-cluster : All components in one OpenShift cluster (dev/demo)
# hub-spoke      : Hub cluster (AI/automation) + Edge cluster(s) (monitoring)
DEPLOYMENT_MODE=single-cluster

# ─────────────────────────────────────────────────────────────────
# OPENSHIFT CLUSTER CONFIGURATION
# ─────────────────────────────────────────────────────────────────

# Hub Cluster (always required)
HUB_API_URL=https://api.hub-cluster.example.com:6443
HUB_USERNAME=kubeadmin
HUB_PASSWORD=
HUB_TOKEN=

# Edge Cluster (required only for hub-spoke mode)
SPOKE_API_URL=https://api.edge-cluster.example.com:6443
SPOKE_USERNAME=kubeadmin
SPOKE_PASSWORD=
SPOKE_TOKEN=

# OpenShift namespace where components are deployed
NAMESPACE=ai-driven-network

# ─────────────────────────────────────────────────────────────────
# AI MODEL CONFIGURATION
# ─────────────────────────────────────────────────────────────────

# Granite 4.0 model serving endpoint
# If using RHOAI 3.3 with vLLM, this is typically:
# https://granite-vllm-predictor.rhoai.svc:8080/v1
GRANITE_MODEL_ENDPOINT=https://granite-vllm-predictor.rhoai.svc:8080/v1
GRANITE_MODEL_NAME=ibm/granite-4-h-tiny

# OpenAI API key (if using external OpenAI instead of local Granite)
# Leave empty to use local Granite via RHOAI
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────
# KAFKA EVENT STREAMING
# ─────────────────────────────────────────────────────────────────

# Kafka bootstrap servers (in-cluster)
KAFKA_BOOTSTRAP_SERVERS=kafka-cluster-kafka-bootstrap.kafka.svc:9093
KAFKA_TLS_ENABLED=true
KAFKA_SECURITY_PROTOCOL=SSL

# Kafka topics
KAFKA_LOGS_TOPIC=network-logs
KAFKA_INCIDENTS_TOPIC=incidents
KAFKA_REMEDIATION_TOPIC=remediation-events

# ─────────────────────────────────────────────────────────────────
# DATABASE & STORAGE
# ─────────────────────────────────────────────────────────────────

# PostgreSQL (pgvector for RAG + checkpoints)
POSTGRES_HOST=postgres-postgresql.ai-driven-network.svc
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=ai-driven_network
POSTGRES_VECTOR_DB=rag_knowledge

# MinIO (object storage for documents)
# The default Helm install now deploys MinIO and creates the `minio` secret.
# These values are mainly for local development or non-Helm deployments.
MINIO_ENDPOINT=minio.hub.svc:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=runbooks

# ─────────────────────────────────────────────────────────────────
# AUTOMATION & ORCHESTRATION
# ─────────────────────────────────────────────────────────────────

# Red Hat Ansible Automation Platform (AAP)
AAP_CONTROLLER_URL=https://aap-controller.automation.svc
AAP_API_USERNAME=admin
AAP_API_PASSWORD=
AAP_API_TOKEN=
AAP_ORGANIZATION_ID=1
AAP_PROJECT_ID=1
AAP_INVENTORY_ID=1

# Template for Lightspeed-assisted playbook generation
AAP_LIGHTSPEED_TEMPLATE=lightspeed-generate-and-run

# ─────────────────────────────────────────────────────────────────
# MULTI-CLUSTER MANAGEMENT
# ─────────────────────────────────────────────────────────────────

# Advanced Cluster Management (ACM) for hub-spoke mode
ACM_HUB_CLUSTER_NAME=hub
ACM_SPOKE_CLUSTER_NAMES=edge-site-1,edge-site-2
ACM_IMAGE_REGISTRY=quay.io/acm-d

# ─────────────────────────────────────────────────────────────────
# OBSERVABILITY & LOGGING
# ─────────────────────────────────────────────────────────────────

# Langfuse for LLM observability and trace collection
# When deployed via ENABLE_LANGFUSE=true, these are auto-generated in the
# langfuse-secrets K8s secret. Retrieve with:
#   kubectl get secret langfuse-secrets -n hub -o jsonpath='{.data.langfuse-public-key}' | base64 -d
#   kubectl get secret langfuse-secrets -n hub -o jsonpath='{.data.langfuse-secret-key}' | base64 -d
LANGFUSE_URL=http://langfuse-web.hub.svc:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# LokiStack (optional, for log storage)
LOKI_URL=http://loki-distributor.logging.svc:3100
LOKI_TENANT_ID=1

# ─────────────────────────────────────────────────────────────────
# EXTERNAL INTEGRATIONS
# ─────────────────────────────────────────────────────────────────

# ServiceNow (for escalation tickets)
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_API_USERNAME=api_user
SERVICENOW_API_PASSWORD=
SERVICENOW_TABLE=incident

# Slack (for notifications)
SLACK_BOT_TOKEN=xoxb-
SLACK_CHANNEL=#ai-driven-network
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/

# ─────────────────────────────────────────────────────────────────
# QUICKSTART BEHAVIOR
# ─────────────────────────────────────────────────────────────────

# Enable failure injection for testing
ENABLE_FAILURE_INJECTION=false

# Sample failure scenarios to inject
FAILURE_SCENARIOS=nginx_crash,memory_leak,disk_full

# Timeout for remediation (seconds)
REMEDIATION_TIMEOUT=300

# Require human approval for critical remediations
REQUIRE_APPROVAL=false

# ─────────────────────────────────────────────────────────────────
# DEBUG & DEVELOPMENT
# ─────────────────────────────────────────────────────────────────

# Log level for components
LOG_LEVEL=INFO

# Enable verbose debug output
DEBUG=false

# Langfuse debug mode
LANGFUSE_DEBUG=false
