{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nginx-logs.schema.json",
  "title": "Nginx Log Event (system-alerts topic)",
  "description": "Schema for log events published to the system-alerts Kafka topic. Produced by the chatbot BFF demo trigger and edge log forwarders.",
  "type": "object",
  "required": ["@timestamp", "message", "level", "kubernetes", "labels"],
  "properties": {
    "@timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the event"
    },
    "incident_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for end-to-end traceability (generated by trigger source)"
    },
    "message": {
      "type": "string",
      "description": "Human-readable log message describing the failure"
    },
    "level": {
      "type": "string",
      "enum": ["error", "warn", "info"],
      "description": "Log severity level"
    },
    "kubernetes": {
      "type": "object",
      "required": ["namespace_name", "pod_name", "container_name"],
      "properties": {
        "namespace_name": { "type": "string" },
        "pod_name": { "type": "string" },
        "container_name": { "type": "string" }
      }
    },
    "labels": {
      "type": "object",
      "required": ["edge_site_id"],
      "properties": {
        "edge_site_id": {
          "type": "string",
          "description": "Identifier for the edge cluster site"
        },
        "dark_noc_demo": {
          "type": "string",
          "enum": ["true", "false"],
          "description": "Whether this event was triggered by a demo"
        },
        "dark_noc_scenario": {
          "type": ["string", "null"],
          "enum": ["crashloop", "oom", "lightspeed", "escalation", null],
          "description": "Demo failure scenario type"
        }
      }
    }
  }
}
